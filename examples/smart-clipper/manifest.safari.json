{
	"host_permissions": [
		"https://cdn.jsdelivr.net/*"
	],
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "downloads"
  ],
  "commands": {
    "start-ocr-clipping": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Start OCR clipping on the active tab"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "libs/tesseract/*",
        "libs/tesseract/lang-data/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
