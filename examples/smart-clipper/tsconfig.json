{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": [
      "@hexajs/ports/hexa.web.ext"
    ],
    "paths": {
      "@contract/*": ["./src/contract/*"],
      "@libs/*": ["./src/libs/*"]
    },
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": [
    "src/**/*",
    "src/contract/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}