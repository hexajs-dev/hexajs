{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "types": [
      "vite/client",
      "@hexajs/ports/hexa.web.ext"
    ],
    "paths": {
      "@contract/*": [
        "../../src/contract/*"
      ]
    },
  },
  "include": [
    "src"
  ]
}