{
  "name": "@hexajs-dev/common",
  "version": "1.0.4",
  "license": "MIT",
  "description": "Shared DI container, decorators, and tokens for HexaJS",
  "homepage": "https://hexajs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexajs-dev/hexajs.git",
    "directory": "packages/common"
  },
  "bugs": {
    "url": "https://github.com/hexajs-dev/hexajs/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"Error: no lint specified\" && exit 1",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
