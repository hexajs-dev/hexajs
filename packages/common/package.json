{
  "name": "@hexajs-dev/common",
  "version": "0.9.1",
  "description": "Shared DI container, decorators, and tokens for HexaJS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "echo \"Error: no lint specified\" && exit 1",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
