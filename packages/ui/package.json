{
  "name": "@hexajs-dev/ui",
  "version": "0.9.3-beta.11",
  "license": "MIT",
  "description": "HexaJS UI support package",
  "homepage": "https://hexajs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexajs-dev/hexajs.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/hexajs-dev/hexajs/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "browser": "dist/browser.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs",
      "default": "./dist/browser.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs",
      "default": "./dist/react.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "import": "./dist/vue.js",
      "require": "./dist/vue.cjs",
      "default": "./dist/vue.js"
    },
    "./hexa-metadata.json": "./dist/hexa-metadata.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hexajs-dev/common": "workspace:^",
    "@hexajs-dev/core": "workspace:^",
    "@hexajs-dev/ports": "workspace:^"
  },
  "peerDependencies": {
    "vite": ">=5.0.0",
    "@vitejs/plugin-react": ">=4.0.0",
    "@vitejs/plugin-vue": ">=5.0.0",
    "vue": ">=3.5.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-react": {
      "optional": true
    },
    "@vitejs/plugin-vue": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hexajs-dev/common": "workspace:^",
    "@hexajs-dev/core": "workspace:^",
    "@hexajs-dev/ports": "workspace:^",
    "@types/node": "^25.0.10",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "vue": "^3.5.13",
    "jsdom": "^25.0.1",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.1"
  }
}
