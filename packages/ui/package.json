{
  "name": "@hexajs/ui",
  "version": "0.9.1",
  "description": "HexaJS UI support package",
  "main": "dist/index.js",
  "browser": "dist/browser.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs",
      "default": "./dist/browser.js"
    },
    "./hexa-metadata.json": "./dist/hexa-metadata.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@hexajs/common": "workspace:*",
    "@hexajs/core": "workspace:*",
    "@hexajs/ports": "workspace:*",
    "vite": ">=5.0.0",
    "@vitejs/plugin-react": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hexajs/common": "workspace:*",
    "@hexajs/core": "workspace:*",
    "@hexajs/ports": "workspace:*",
    "@types/node": "^25.0.10",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  }
}
