{
  "name": "@hexajs-dev/ui",
  "version": "0.9.3-alpha.1",
  "license": "MIT",
  "description": "HexaJS UI support package",
  "homepage": "https://hexajs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexajs-dev/hexajs.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/hexajs-dev/hexajs/issues"
  },
  "main": "dist/index.js",
  "browser": "dist/browser.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs",
      "default": "./dist/browser.js"
    },
    "./hexa-metadata.json": "./dist/hexa-metadata.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@hexajs-dev/common": "workspace:*",
    "@hexajs-dev/core": "workspace:*",
    "@hexajs-dev/ports": "workspace:*",
    "vite": ">=5.0.0",
    "@vitejs/plugin-react": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@vitejs/plugin-react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@hexajs-dev/common": "workspace:*",
    "@hexajs-dev/core": "workspace:*",
    "@hexajs-dev/ports": "workspace:*",
    "@types/node": "^25.0.10",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.1"
  }
}
