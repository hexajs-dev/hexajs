{
  "name": "@hexajs/ports",
  "version": "0.9.1",
  "description": "HexaJS platform ports for background/content/ui contexts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./hexa-metadata.json": "./dist/hexa-metadata.json",
    "./hexa.web.ext": "./dist/hexa.web.ext.d.ts",
    "./hexa.web.ext.d.ts": "./dist/hexa.web.ext.d.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "echo \"No tests yet\"",
    "lint": "echo \"Error: no lint specified\" && exit 1",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@hexajs/common": "workspace:*",
    "@types/node": "^25.0.10",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@hexajs/common": "workspace:*",
    "typescript": "^5.0.0"
  }
}
