{
  "name": "@hexajs-dev/core",
  "version": "0.9.3-alpha.4",
  "license": "MIT",
  "description": "Core contracts, decorators, and services for HexaJS",
  "homepage": "https://hexajs.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hexajs-dev/hexajs.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/hexajs-dev/hexajs/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./hexa-metadata.json": "./dist/hexa-metadata.json",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"Error: no lint specified\" && exit 1",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@hexajs-dev/common": "workspace:*",
    "@hexajs-dev/ports": "workspace:*",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
