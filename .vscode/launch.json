{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "name": "Vitest: Current File",
            "request": "launch",
            "program": "${workspaceFolder}/packages/core/node_modules/vitest/vitest.mjs",
            "args": [
                "run",
                "${relativeFile}",
                "--config",
                "${workspaceFolder}/packages/core/vitest.config.ts"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node",
            "name": "Vitest: Watch",
            "request": "launch",
            "program": "${workspaceFolder}/packages/core/node_modules/vitest/vitest.mjs",
            "args": [
                "watch",
                "${relativeFile}",
                "--config",
                "${workspaceFolder}/packages/core/vitest.config.ts"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node",
            "name": "Vitest: All Tests",
            "request": "launch",
            "program": "${workspaceFolder}/packages/core/node_modules/vitest/vitest.mjs",
            "args": [
                "run",
                "--config",
                "${workspaceFolder}/packages/core/vitest.config.ts"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "type": "node",
            "name": "Debug Current TS File",
            "request": "launch",
            "runtimeExecutable": "node",
            "runtimeArgs": [
                "-r",
                "ts-node/register"
            ],
            "program": "${file}",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "env": {
                "TS_NODE_PROJECT": "${workspaceFolder}/packages/core/tsconfig.json"
            },
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**"
            ]
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Hexa CLI - v2",
            "runtimeExecutable": "pnpm",
            "runtimeArgs": [
                "--filter",
                "@hexajs/cli",
                "run",
                "debug"
            ],
            "skipFiles": [
                "<node_internals>/**"
            ],
            "console": "internalConsole",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}